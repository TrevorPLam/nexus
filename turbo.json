{
  "$schema": "https://turbo.build/schema.json",
  "futureFlags": {
    "globalConfiguration": true
  },
  "global": {
    "inputs": [".env"],
    "env": ["CI", "NODE_ENV", "TURBO_TOKEN", "TURBO_TEAM"]
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*", "tsconfig.json"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**", ".turbo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*", "eslint.config.mjs", ".prettierrc"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*", "tsconfig.json"]
    },
    "//#format": {
      "cache": false
    },
    "//#format:check": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*", "tsconfig.json", "vitest.config.ts"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
