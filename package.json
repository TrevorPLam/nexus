{
  "name": "life-os",
  "version": "0.0.1",
  "private": true,
  "description": "Life OS - Personal productivity system",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10"
    },
    "runtime": {
      "name": "node",
      "version": "22"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --ignore-path ./.prettierignore . --ignore-unknown --write",
    "format:check": "prettier --ignore-path ./.prettierignore . --ignore-unknown --check",
    "typecheck": "turbo run typecheck",
    "validate": "turbo run validate",
    "clean": "turbo run clean && rm -rf node_modules",
    "validate:contracts": "pnpm --filter @life-os/contracts exec vitest run test/work.test.ts test/calendar.test.ts",
    "validate:api": "pnpm --filter @life-os/api exec vitest run src/lib src/routes",
    "validate:web": "pnpm --filter @life-os/web exec vitest run src/app/work src/app/calendar",
    "validate:mobile": "pnpm --filter @life-os/mobile exec vitest run app/work app/calendar",
    "validate:all": "pnpm validate:contracts && pnpm validate:api && pnpm validate:web && pnpm validate:mobile"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "catalog:",
    "@op-engineering/op-sqlite": "catalog:",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import-x": "^4.0.0",
    "globals": "^15.0.0",
    "lefthook": "^2.1.0",
    "prettier": "catalog:",
    "supabase": "^2.109.1",
    "turbo": "^2.9.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  }
}
