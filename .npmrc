# pnpm configuration for Life OS monorepo
# Per pnpm best practices (PR #11189), only auth/registry settings belong in .npmrc
# All other settings are in pnpm-workspace.yaml

# Registry configuration (if needed for private registries)
# registry=https://registry.npmjs.org/

# Auth tokens should use environment variables to avoid committing secrets
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Enforce engine strict mode to fail on incompatible Node/pnpm versions
engine-strict=true
